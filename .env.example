# 必須: 台本・サムネ・JSON整形など（Search 以外）
GEMINI_API_KEY=your_gemini_api_key

# 推奨: ニュース検索（3.5 Flash + Google Search）用の有料枠キー
# GitHub Actions では Repository secrets に同名で登録
GEMINI_API_KEY_SEARCH=your_paid_gemini_api_key

# ニュースビジュアル（OG画像 → チャートフォールバック）
# NEWS_ENRICH_OG=true
# NEWS_MAX_CHART_CAPTURES=6
# NEWS_OG_FETCH_TIMEOUT_SEC=15

# 指数チャート（Yahoo Selenium）
# MARKET_CHART_SELECTOR_WAIT_SEC=25
# MARKET_CHART_RENDER_WAIT_SEC=10
